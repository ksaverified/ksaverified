{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 * * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}