{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 120
        }
    },
    "redirects": [
        {
            "source": "/login",
            "destination": "/customers/login",
            "permanent": false
        },
        {
            "source": "/client-dashboard(.*)",
            "destination": "/customers$1",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/seo?action=sitemap"
        },
        {
            "source": "/robots.txt",
            "destination": "/api/seo?action=robots"
        },
        {
            "source": "/api/admin_sfa",
            "destination": "/api/sfa"
        },
        {
            "source": "/api/lookup",
            "destination": "/api/leads?action=lookup"
        },
        {
            "source": "/api/register-lead",
            "destination": "/api/leads?action=register-lead"
        },
        {
            "source": "/api/track",
            "destination": "/api/system?action=track"
        },
        {
            "source": "/api/trigger",
            "destination": "/api/system?action=trigger"
        },
        {
            "source": "/api/translate",
            "destination": "/api/system?action=translate"
        },
        {
            "source": "/api/send-message",
            "destination": "/api/system?action=send-message"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/site/(.*)",
            "destination": "/api/preview?id=$1"
        },
        {
            "source": "/customers/:path((?!.*\\.).*)",
            "destination": "/customers/index.html"
        },
        {
            "source": "/(manage|admin|pipeline|websites|map|answers|analytics|settings|whatsapp|interest-confirmed|logs)(.*)",
            "destination": "/index.html"
        },
        {
            "source": "/:slug((?!.*\\.).*)",
            "destination": "/api/vanity?slug=$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}